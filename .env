COMPOSE_PROJECT_NAME=dyadia

FDB_API_VERSION=730
FDB_VERSION=7.3.71
FDB_COORDINATOR=fdb-coordinator
FDB_NETWORKING_MODE=container
FDB_COORDINATOR_PORT=4500

FDB_CLUSTER_FILE=./fdb.cluster

# Goose migration
GOOSE_DRIVER=postgres
GOOSE_DBSTRING=postgres://dyadia:dyadia@localhost:5432/dyadia
GOOSE_MIGRATION_DIR=./sql/migrations
# GOOSE_TABLE=custom.goose_migrations
